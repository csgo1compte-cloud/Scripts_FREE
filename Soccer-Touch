    Callback = function(v)
        aimGoalActive = v
        if v then
            StartAimGoal()
            VoidUI:Notify({ Title = "Aim Goal", Message = "Enabled!", Type = "success", Duration = 2 })
        else
            StopAimGoal()
            VoidUI:Notify({ Title = "Aim Goal", Message = "Disabled.", Type = "info", Duration = 2 })
        end
    end,
})
end)
