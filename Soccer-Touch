Tab:AddButton({
    Label    = "⚽  Goal A",
    Colors   = { Color3.fromRGB(130, 80, 255), Color3.fromRGB(220, 80, 160) },
    Callback = function()
        selectedGoal = selectedGoal == goalA and nil or goalA
        UpdateHighlights()
        VoidUI:Notify({
            Title   = "Goal",
            Message = selectedGoal == goalA and "Goal A selected" or "Selection cleared",
            Type    = "info", Duration = 2,
        })
    end,
})

Tab:AddButton({
    Label    = "⚽  Goal B",
    Colors   = { Color3.fromRGB(130, 80, 255), Color3.fromRGB(220, 80, 160) },
    Callback = function()
        selectedGoal = selectedGoal == goalB and nil or goalB
        UpdateHighlights()
        VoidUI:Notify({
            Title   = "Goal",
            Message = selectedGoal == goalB and "Goal B selected" or "Selection cleared",
            Type    = "info", Duration = 2,
        })
    end,
})



-- ── Ball Snap ──
Tab:AddLabel("Ball Snap")

Tab:AddLabel("⚠️ WARNING : Ball Snap locks the ball to your feet at all times. This is extremely powerful and very noticeable to other players. Use at your own risk.")

Tab:AddSlider({
    Label    = "Snap radius",
    Min      = 2, Max = 20, Default = SNAP_RADIUS,
    Suffix   = " st",
    Callback = function(v) SNAP_RADIUS = v end,
})

Tab:AddToggle({
    Label    = "Ball Snap",
    Default  = false,
    Callback = function(v)
        snapActive = v
        if v then
            StartSnap()
            VoidUI:Notify({ Title = "Ball Snap", Message = "Snap enabled!", Type = "success", Duration = 2 })
        else
            StopSnap()
            VoidUI:Notify({ Title = "Ball Snap", Message = "Snap disabled.", Type = "info", Duration = 2 })
        end
    end,
})

-- ── Auto Aim ──
Tab:AddLabel("Auto Aim")

Tab:AddToggle({
    Label    = "Auto aim ball",
    Default  = false,
    Callback = function(v)
        aimBallActive = v
        if v then
            StartAimBall()
            VoidUI:Notify({ Title = "Aim Ball", Message = "Enabled!", Type = "success", Duration = 2 })
        else
            StopAimBall()
            VoidUI:Notify({ Title = "Aim Ball", Message = "Disabled.", Type = "info", Duration = 2 })
        end
    end,
})

Tab:AddToggle({
    Label    = "Auto aim goal",
