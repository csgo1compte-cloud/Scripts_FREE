VoidUI:CreateFloatingButton({
    Text     = "TP\nBall",
    Position = UDim2.new(0, 20, 0.5, -70),
    Size     = UDim2.new(0, 58, 0, 58),
    Callback = function()
        TpToBall()
        VoidUI:Notify({ Title = "Teleport", Message = "Teleported behind the ball!", Type = "info", Duration = 2 })
    end,
})

VoidUI:CreateFloatingButton({
    Text     = "Ball\nFeet",
    Position = UDim2.new(0, 20, 0.5, 0),
    Size     = UDim2.new(0, 58, 0, 58),
    Callback = function()
        BallToFeet()
        VoidUI:Notify({ Title = "Ball", Message = "Ball at your feet!", Type = "success", Duration = 2 })
    end,
})

