local function parseShortNumber(text)
    if not text then return 0 end
    local num, suffix = text:match("([%d%.]+)%s*([A-Za-z]*)")
    if not num then return 0 end
    num = tonumber(num) or 0
    suffix = suffix:upper()
    local mult = {
        K = 1e3, M = 1e6, B = 1e9, T = 1e12,
        QA = 1e15, QI = 1e18, SX = 1e21, SP = 1e24,
    }
    return num * (mult[suffix] or 1)
end


local function getCash()
    local ok, label = pcall(function()
        return player.PlayerGui.ScreenGui.CashText
    end)
    if not ok or not label then return 0 end
    return parseShortNumber(label.Text)
end


local function getUpgradePrice(upgradeKey)
    local ok, label = pcall(function()
        return player.PlayerGui.ScreenGui.Frames.UpgradesFrame.Frame[upgradeKey].Upgrade.TextLabel
    end)
    if not ok or not label then return math.huge end
    return parseShortNumber(label.Text)
end


