-- ── Constantes ──
local MIDDLE_X        = 412.5
local MIDDLE_Z        = 135
local MIDDLE_HALF_X   = 71.5   -- 143 / 2
local MIDDLE_HALF_Z   = 73.25  -- 146.5 / 2
local DETECT_RADIUS   = 50     -- studs depuis le pivot de la base


local autoLockEnabled = false
local lockConnection  = nil


local function isInMiddle(pos)
    return math.abs(pos.X - MIDDLE_X) <= MIDDLE_HALF_X
        and math.abs(pos.Z - MIDDLE_Z) <= MIDDLE_HALF_Z
end


-- Distance perpendiculaire 2D (XZ) d'un point à une droite
local function isHeadingToBase(pos1, pos2, basePos)
    local dx = pos2.X - pos1.X
    local dz = pos2.Z - pos1.Z
    local len = math.sqrt(dx*dx + dz*dz)
    if len < 0.001 then return false end
    dx, dz = dx/len, dz/len


    local px = basePos.X - pos1.X
    local pz = basePos.Z - pos1.Z


    -- Distance perpendiculaire (produit vectoriel 2D)
    local dist = math.abs(px * dz - pz * dx)


    -- t > 0 = la base est devant la nuke, pas derrière
    local t = px * dx + pz * dz


    return dist <= DETECT_RADIUS and t > 0
end


local function canLockBase()
    local ok, label = pcall(function()
        return player.PlayerGui.ScreenGui.Top.LockBase.TextLabel
    end)
    if not ok or not label then return false end
    return label.Text == "Lock Base"
end


local function handleNuke(nuke)
    task.wait(0.1) -- laisser les attributes se charger
    if not nuke.Parent then return end
    if nuke:GetAttribute("LauncherUserId") == player.UserId then return end


    local sampleA = nil


    while nuke.Parent and autoLockEnabled do
        task.wait(0.2)
        if not nuke.Parent then return end -- nuke a touché sa cible, on ignore


        local pos = nuke.Position


        if isInMiddle(pos) then
            -- Nuke dans la zone du middle → reset et attendre qu'elle sorte
            sampleA = nil
        else
            if not sampleA then
                sampleA = pos
            else
                -- On a 2 samples consécutifs hors du middle → on prédit
                local basePos = getMyBasePosition()
                if not basePos then return end


                if isHeadingToBase(sampleA, pos, basePos) then
                    if canLockBase() then
                        RequestLockBase:FireServer()
                        Ui:Notify({
                            Title    = "Auto Lock",
                            Content  = "Incoming nuke detected — Base locked!",
                            Duration = 4,
                            Image    = 4483362458,
                        })
                    else
                        Ui:Notify({
                            Title    = "Auto Lock",
                            Content  = "Incoming nuke — Lock on cooldown!",
                            Duration = 4,
                            Image    = 4483362458,
                        })
                    end
                end
                return -- traitement terminé pour cette nuke
            end
        end
    end
end


LockTab:CreateToggle({
    Name = "Auto Lock on Attack",
    CurrentValue = false,
    Flag = "AutoLock",
    Callback = function(val)
        autoLockEnabled = val
        if val then
            lockConnection = workspace.ChildAdded:Connect(function(child)
                if child.Name:match("^LaunchedNuke") then
                    task.spawn(handleNuke, child)
                end
            end)
            -- Nukes déjà en vol au moment de l'activation
            for _, child in ipairs(workspace:GetChildren()) do
                if child.Name:match("^LaunchedNuke") then
                    task.spawn(handleNuke, child)
                end
            end
            Ui:Notify({ Title = "Auto Lock", Content = "Enabled",  Duration = 2, Image = 4483362458 })
        else
            autoLockEnabled = false
            if lockConnection then
                lockConnection:Disconnect()
                lockConnection = nil
            end
            Ui:Notify({ Title = "Auto Lock", Content = "Disabled", Duration = 2, Image = 4483362458 })
        end
    end,
})
end)