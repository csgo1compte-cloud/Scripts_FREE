-- ── Config ──
local WALK_SPEED    = 45
local DEFAULT_SPEED = 16
local DROP_DEBOUNCE = 0.75


-- ── State ──
local mergeRunning  = false
local manualUnblock = false
local isHolding     = false
local heldTier      = nil
local loopThread    = nil
local allowPickup   = false


-- ── Hook PickUp — UNE SEULE FOIS ──
local hookOriginal
hookOriginal = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and self == PickUp then
        if manualUnblock or not mergeRunning then
            return hookOriginal(self, ...)
        end
        if allowPickup then
            allowPickup = false
            return hookOriginal(self, ...)
        end
        return
    end
    return hookOriginal(self, ...)
end)


-- ── Events natifs ──
HoldStarted.OnClientEvent:Connect(function(tier)
    isHolding = true
    heldTier  = tier
end)
HoldEnded.OnClientEvent:Connect(function()
    isHolding = false
    heldTier  = nil
end)


-- ── Helpers communs ──
local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end


local function getHum()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end


local function getMyNukesFolder()
    local Bases = workspace:FindFirstChild("Bases")
    if not Bases then return nil end
    for _, base in ipairs(Bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, n in ipairs(nukes:GetChildren()) do
                if n:GetAttribute("OwnerUserId") == player.UserId then
                    return nukes
                end
            end
        end
    end
    return nil
end


local function getMyBasePosition()
    local Bases = workspace:FindFirstChild("Bases")
    if not Bases then return nil end
    for _, base in ipairs(Bases:GetChildren()) do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, n in ipairs(nukes:GetChildren()) do
                if n:GetAttribute("OwnerUserId") == player.UserId then
                    local model = base:FindFirstChild("Model")
                    if model then
                        local ok, pivot = pcall(function() return model:GetPivot() end)
                        if ok then return pivot.Position end
                    end
                end
            end
        end
    end
    return nil
end


local function getFloorNukes(folder)
    local result = {}
    for _, n in ipairs(folder:GetChildren()) do
        local state = n:GetAttribute("State")
        if n:IsA("BasePart") and (state == "floor" or state == "based") then
            table.insert(result, n)
        end
    end
    return result
end


local function doPickup(nuke)
    allowPickup = true
    PickUp:FireServer(nuke)
    task.delay(2, function()
        if allowPickup then allowPickup = false end
    end)
end


local function doDrop()
    local hrp = getHRP()
    if not hrp then return end
    Drop:FireServer(hrp.CFrame)
    task.wait(DROP_DEBOUNCE + 0.1)
end


-- ── Loop Merge ──
local function doMergeLoop()
    if isHolding then doDrop() end


    while mergeRunning do
        task.wait(0.15)


        local hrp = getHRP()
        if not hrp then continue end
        local hum = getHum()
        if not hum then continue end
        local folder = getMyNukesFolder()
        if not folder then continue end


        local nukes = getFloorNukes(folder)


        local byTier = {}
        for _, n in ipairs(nukes) do
            local tier = n:GetAttribute("Tier")
            if tier then
                if not byTier[tier] then byTier[tier] = { count = 0, nukes = {} } end
                byTier[tier].count += 1
                table.insert(byTier[tier].nukes, n)
            end
        end
        if isHolding and heldTier then
            if not byTier[heldTier] then byTier[heldTier] = { count = 0, nukes = {} } end
            byTier[heldTier].count += 1
        end


        local bestTier = nil
        for tier, data in pairs(byTier) do
            if data.count >= 2 and (not bestTier or tier > bestTier) then
                bestTier = tier
            end
        end


        if isHolding then
            hum.WalkSpeed = DEFAULT_SPEED
            if bestTier and heldTier == bestTier then
                local floorPair = byTier[bestTier].nukes[1]
                if floorPair then
                    MergeRequest:FireServer(floorPair)
                    task.wait(0.1)
                end
            elseif bestTier then
                doDrop()
            end
        else
            if bestTier then
                local target = byTier[bestTier].nukes[1]
                local dist = (hrp.Position - target.Position).Magnitude
                if dist <= 6 then
                    if not isHolding then
                        doPickup(target)
                        task.wait(0.3)
                    end
                else
                    hum.WalkSpeed = WALK_SPEED
                    hum:MoveTo(target.Position)
                end
            else
                hum.WalkSpeed = DEFAULT_SPEED
            end
        end
    end


    local hum = getHum()
    if hum then hum.WalkSpeed = DEFAULT_SPEED end
end


MergeTab:CreateToggle({
    Name = "Auto Merge",
    CurrentValue = false,
    Flag = "AutoMerge",
    Callback = function(val)
        mergeRunning = val
        if val then
            manualUnblock = false
            loopThread = task.spawn(doMergeLoop)
            Ui:Notify({ Title = "Auto Merge", Content = "Enabled", Duration = 2, Image = 4483362458 })
        else
            mergeRunning = false
            allowPickup  = false
            if loopThread then task.cancel(loopThread); loopThread = nil end
            local hum = getHum()
            if hum then hum.WalkSpeed = DEFAULT_SPEED end
            if isHolding then doDrop() end
            Ui:Notify({ Title = "Auto Merge", Content = "Disabled", Duration = 2, Image = 4483362458 })
        end
    end,
})


